# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fingraph
SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fingraph

# Neo4j Aura (Free Tier) - Get from https://neo4j.com/databases/
NEO4J_URI=neo4j+s://your Neo4j Aura URI
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here
NEO4J_DATABASE=neo4j

# Qdrant
QDRANT_URL=http://localhost:6333

# Redis - Use existing or new
REDIS_URL=redis://localhost:6379

# TrueData (Real-time Data) - Get from https://truedata.in/
TRUEDATA_URL=wss://marketdata.truedata.in
TRUEDATA_USERNAME=your_username
TRUEDATA_PASSWORD=your_password

# OpenAI - Get from https://platform.openai.com/
OPENAI_API_KEY=sk-your_openai_key_here

# Crawl4AI
CRAWL4AI_URL=http://localhost:11202

# App
DEBUG=true
API_V1_PREFIX=/api/v1
